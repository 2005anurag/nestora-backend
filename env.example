# Copy this file to .env and fill in your real Razorpay keys.
# Get these from https://dashboard.razorpay.com/app/keys
# NEVER commit the real .env file or expose RAZORPAY_KEY_SECRET to the frontend.

RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_secret_key_here

# Comma-separated list of allowed frontend origins (your deployed app's URL)
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend-domain.com

PORT=4000
